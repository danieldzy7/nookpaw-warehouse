# MongoDB connection string (include database name in path, e.g. ...mongodb.net/nookpaw_warehouse?...)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/nookpaw_warehouse?retryWrites=true&w=majority

# OpenAI — natural-language assistant (对话助手). Never commit real keys.
OPENAI_API_KEY=sk-proj-replace-me
# Optional model override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
